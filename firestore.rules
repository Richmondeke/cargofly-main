rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to get the current user's profile
    function getCurrentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && getCurrentUser().role == 'admin';
    }
    
    // Data Validation Helpers
    function isString(field) {
      return field is string;
    }
    
    function isValidUserWrite(data) {
      // Require email and role. (displayName might be missing temporarily depending on auth flow, but usually required)
      return (!("email" in data) || isString(data.email)) &&
             (!("displayName" in data) || isString(data.displayName)) &&
             (!("role" in data) || data.role in ['customer', 'admin', 'staff']);
    }

    function isValidShipmentWrite(data) {
      return (!("origin" in data) || isString(data.origin)) &&
             (!("destination" in data) || isString(data.destination)) &&
             (!("status" in data) || data.status in ['Pending', 'In Transit', 'Out for Delivery', 'Delivered', 'Cancelled']) &&
             (!("trackingNumber" in data) || isString(data.trackingNumber));
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      // Users can write their own profile; Admins can write everyone's. Enforce schema.
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin()) && isValidUserWrite(request.resource.data);
    }
    
    // --- Shipments Collection ---
    match /shipments/{shipmentId} {
      allow read: if true; // Temporarily allow public read for tracking functionality.
      
      // Enforce schema on creates and updates
      allow create: if request.auth != null && isValidShipmentWrite(request.resource.data);
      allow update: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin()) && isValidShipmentWrite(request.resource.data);
      allow delete: if isAdmin();
    }
    
    // --- Testimonials Collection ---
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // --- Messages/Support Collection ---
    match /messages/{messageId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null && (request.resource.data.userId == request.auth.uid || isAdmin());
      // For updates/deletes
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // --- Default Deny ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
